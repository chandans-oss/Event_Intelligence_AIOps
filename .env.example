# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_API_BASE_URL=http://localhost:8000/api
VITE_RCA_FLOW_ENDPOINT=/rca/run-flow

# ============================================
# DJANGO BACKEND CONFIGURATION
# ============================================
# Security (REQUIRED: Change SECRET_KEY in production)
DJANGO_SECRET_KEY=change-this-to-a-secure-key-in-production
DJANGO_DEBUG=False
DJANGO_ENVIRONMENT=production

# Allowed hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# CORS Configuration (restrict in production)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://yourdomain.com

# ============================================
# POSTGRES DATABASE CONFIGURATION
# ============================================
# REQUIRED: Update these with your actual database credentials
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=infraondb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here

# ============================================
# EMBEDDING MODEL CONFIGURATION
# ============================================
EMBEDING_MODEL=intfloat/e5-base-v2

# ============================================
# API CONFIGURATION
# ============================================
API_TIMEOUT=30
API_RETRY_ATTEMPTS=3

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
